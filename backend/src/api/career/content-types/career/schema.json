      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "location_type": {
      "type": "enumeration",
      "enum": [
        "Onsite",
        "Remote",
        "Hybrid",
        "Hybrid/remote"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "branch_name": {
      "type": "enumeration",
      "enum": [
        "Auckland",
        "Christchurch",
        "Sydney",
        "Yokohama"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "office": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::office.office",
      "inversedBy": "careers",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
