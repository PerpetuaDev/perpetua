      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "job_type": {
      "type": "enumeration",
      "enum": [
        "Full-time",
        "Part-time",
        "Casual/Temp",
        "Internship"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "job_description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "job_location": {
      "type": "enumeration",
      "enum": [
        "Auckland",
        "Christchurch",
        "Sydney",
        "Yokohama",
