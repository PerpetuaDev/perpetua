{
  "kind": "collectionType",
  "collectionName": "offices",
  "info": {
    "singularName": "office",
    "pluralName": "offices",
    "displayName": "Office"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "office_location": {
      "type": "enumeration",
      "enum": [
        "Auckland",
        "Christchurch",
        "Sydney",
        "Yokohama"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "address_1": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "address_2": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "ward": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "city": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "prefecture": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "city_or_state": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "country": {
      "type": "enumeration",
      "enum": [
        "New Zealand",
        "Australia",
        "Japan",
        "Korea"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "post_code": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "email": {
      "type": "email",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "phone": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "office_image": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "careers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::career.career",
      "mappedBy": "office",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "mappedBy": "related_offices",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
